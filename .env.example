# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://username:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql+psycopg2://username:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (Member 7) ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=5

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── ML ─────────────────────────────────────────────────────────────────────
DEEPFACE_MODEL=ArcFace
GROQ_API_KEY=your_groq_api_key_here

# ── Storage / S3 (Member 3 — KYC docs) ────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=neobank-kyc-docs
AWS_REGION=eu-central-1

# ── Email (Member 5) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000