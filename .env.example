# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://username:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql+psycopg2://username:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (Member 7) ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=5

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── ML ─────────────────────────────────────────────────────────────────────
DEEPFACE_MODEL=ArcFace
GROQ_API_KEY=your_groq_api_key_here

# ── Storage / S3 (Member 3 — KYC docs) ────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=neobank-kyc-docs
AWS_REGION=eu-central-1
S3_BUCKET=neobank-kyc-docs
S3_REGION=eu-central-1
S3_ENDPOINT_URL=

# ── Email (Member 5) ───────────────────────────────────────────────────────
EMAIL_PROVIDER=console
EMAIL_FROM="NeoBank Lebanon <no-reply@neobank.local>"

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

SENDGRID_API_KEY=

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# Twilio (SMS OTP delivery)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555555555